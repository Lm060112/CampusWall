.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f6f8;
  overflow: hidden;
}

.feed-scroll {
  flex: 1;
  height: 0;
}

.feed-inner {
  padding: 24rpx 32rpx 32rpx;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.feed-inner--thumb {
  padding-bottom: calc(260rpx + env(safe-area-inset-bottom));
}

/* 校园热搜（参考微博双列布局） */
.hot-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 24rpx 20rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid #f0f0f0;
}

.hot-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.hot-header-left {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.hot-header-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #323233;
}

.hot-header-link {
  font-size: 24rpx;
  color: #ff6a00;
}

.hot-grid {
  display: flex;
  gap: 16rpx;
}

.hot-col {
  flex: 1;
  min-width: 0;
}

.hot-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  min-height: 40rpx;
}

.hot-item:active {
  opacity: 0.65;
}

.hot-item--active .hot-item-text {
  color: #ff6a00;
  font-weight: 600;
}

.hot-item-text {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  color: #323233;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hot-tag {
  flex-shrink: 0;
  margin-left: 8rpx;
  font-size: 20rpx;
  line-height: 1;
  padding: 4rpx 8rpx;
  border-radius: 6rpx;
  color: #fff;
  font-weight: 500;
}

.hot-tag--hot {
  background: #ff6a00;
}

.hot-tag--new {
  background: #07c160;
}

.hot-tag--rec {
  background: #1989fa;
}

.hot-tag--live {
  background: #ee0a24;
}

.hot-more {
  text-align: center;
  font-size: 26rpx;
  color: #ff6a00;
  padding-top: 8rpx;
}

.hot-more:active {
  opacity: 0.65;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #323233;
}

.filter-hint {
  font-size: 26rpx;
  font-weight: 500;
  color: #ff6a00;
}

.filter-clear {
  font-size: 24rpx;
  color: #969799;
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* 底部搜索框式发帖栏 */
.post-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  background: #fff;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #ebedf0;
}

.post-thumb-row {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 16rpx;
}

.post-thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  display: block;
}

.post-thumb-del {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
}

.post-input-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.post-icon-btn {
  flex-shrink: 0;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.post-icon-btn:active {
  opacity: 0.7;
}

.search-input-wrap {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  background: #f5f6f8;
  border-radius: 36rpx;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  border: 1rpx solid #ebedf0;
}

.search-input {
  flex: 1;
  width: 100%;
  height: 72rpx;
  font-size: 28rpx;
  color: #323233;
}

.search-placeholder {
  color: #c8c9cc;
  font-size: 28rpx;
}

.send-btn {
  flex-shrink: 0;
  font-size: 28rpx;
  font-weight: 500;
  color: #1989fa;
  padding: 0 8rpx;
  line-height: 72rpx;
}

.send-btn:active {
  opacity: 0.7;
}

.send-btn--disabled {
  color: #c8c9cc;
}

.empty {
  text-align: center;
  color: #969799;
  font-size: 28rpx;
  padding: 80rpx 32rpx;
  background: #fff;
  border-radius: 16rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid #f0f0f0;
}

.card-meta {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.avatar--anon {
  background: linear-gradient(135deg, #c8c9cc 0%, #969799 100%);
}

.avatar--real {
  background: linear-gradient(135deg, #4fc3f7 0%, #1989fa 100%);
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-fallback {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  line-height: 1;
}

.card-author {
  font-size: 28rpx;
  font-weight: 500;
  color: #323233;
}

.card-text {
  display: block;
  font-size: 30rpx;
  line-height: 1.65;
  color: #323233;
  word-break: break-all;
  margin-bottom: 16rpx;
}

.card-pic-wrap {
  width: 100%;
  height: 360rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
  background: #f2f3f5;
}

.card-pic {
  width: 100%;
  height: 100%;
  display: block;
}

.card-pic:active {
  opacity: 0.92;
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-top: 8rpx;
}

.card-time {
  font-size: 24rpx;
  color: #969799;
  flex: 1;
  min-width: 0;
}

.card-footer-actions {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  gap: 8rpx;
}

.like-wrap {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  padding: 8rpx 12rpx;
  margin: -8rpx 0;
  border-radius: 999rpx;
}

.like-wrap:active {
  opacity: 0.65;
}

.like-num {
  margin-left: 8rpx;
  font-size: 26rpx;
  color: #646566;
  font-weight: 500;
  min-width: 2em;
  text-align: left;
}

.delete-wrap {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  padding: 8rpx 12rpx;
  margin: -8rpx -12rpx -8rpx 0;
  border-radius: 999rpx;
}

.delete-wrap:active {
  opacity: 0.65;
}

.delete-text {
  margin-left: 6rpx;
  font-size: 26rpx;
  color: #c8c9cc;
}
