.page {
  min-height: 100vh;
  padding: 24rpx 32rpx 48rpx;
  box-sizing: border-box;
  background: #f5f6f8;
}

.section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #323233;
  margin-bottom: 20rpx;
}

.post-form {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 24rpx 28rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.post-field {
  background: #f7f8fa;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  padding: 8rpx 16rpx !important;
}

.uploader-row {
  margin-bottom: 20rpx;
}

.post-uploader {
  display: block;
}

.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 8rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 24rpx;
}

.toolbar-label {
  font-size: 28rpx;
  color: #646566;
}

.list-section {
  padding-bottom: 24rpx;
}

.empty {
  text-align: center;
  color: #969799;
  font-size: 28rpx;
  padding: 80rpx 32rpx;
  background: #fff;
  border-radius: 16rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid #f0f0f0;
}

.card-meta {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.avatar--anon {
  background: linear-gradient(135deg, #c8c9cc 0%, #969799 100%);
}

.avatar--real {
  background: linear-gradient(135deg, #4fc3f7 0%, #1989fa 100%);
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-fallback {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  line-height: 1;
}

.card-author {
  font-size: 28rpx;
  font-weight: 500;
  color: #323233;
}

.card-text {
  display: block;
  font-size: 30rpx;
  line-height: 1.65;
  color: #323233;
  word-break: break-all;
  margin-bottom: 16rpx;
}

.card-pic-wrap {
  width: 100%;
  height: 360rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
  background: #f2f3f5;
}

.card-pic {
  width: 100%;
  height: 100%;
  display: block;
}

.card-pic:active {
  opacity: 0.92;
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-top: 8rpx;
}

.card-time {
  font-size: 24rpx;
  color: #969799;
  flex: 1;
  min-width: 0;
}

.card-footer-actions {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  gap: 8rpx;
}

.like-wrap {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  padding: 8rpx 12rpx;
  margin: -8rpx 0;
  border-radius: 999rpx;
}

.like-wrap:active {
  opacity: 0.65;
}

.like-num {
  margin-left: 8rpx;
  font-size: 26rpx;
  color: #646566;
  font-weight: 500;
  min-width: 2em;
  text-align: left;
}

.delete-wrap {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  padding: 8rpx 12rpx;
  margin: -8rpx -12rpx -8rpx 0;
  border-radius: 999rpx;
}

.delete-wrap:active {
  opacity: 0.65;
}

.delete-text {
  margin-left: 6rpx;
  font-size: 26rpx;
  color: #c8c9cc;
}
