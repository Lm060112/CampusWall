<view class="page">
  <view class="section post-form">
    <view class="section-title">发帖</view>
    <van-field
      value="{{ content }}"
      type="textarea"
      placeholder="分享你的新鲜事..."
      autosize="{{ fieldAutosize }}"
      border="{{ false }}"
      custom-class="post-field"
      bind:change="onContentChange"
    />
    <view class="uploader-row">
      <van-uploader
        file-list="{{ fileList }}"
        max-count="{{ 1 }}"
        preview-size="176rpx"
        upload-icon="plus"
        deletable="{{ true }}"
        bind:after-read="onUploaderAfterRead"
        bind:delete="onUploaderDelete"
        custom-class="post-uploader"
      />
    </view>
    <view class="toolbar">
      <text class="toolbar-label">匿名发帖</text>
      <van-switch checked="{{ anonymousPost }}" bind:change="onAnonymousChange" />
    </view>
    <van-button
      type="primary"
      block
      round
      loading="{{ publishing }}"
      disabled="{{ publishing }}"
      bind:click="onPublish"
    >
      发布
    </van-button>
  </view>

  <view class="section list-section">
    <view class="section-title">最新动态</view>
    <view wx:if="{{ !loading && posts.length === 0 }}" class="empty">暂无帖子，来发第一条吧</view>
    <view wx:for="{{ posts }}" wx:key="_id" class="card">
      <view class="card-meta">
        <view class="avatar {{ item.is_anonymous ? 'avatar--anon' : 'avatar--real' }}">
          <image wx:if="{{ item.avatarUrl }}" class="avatar-img" src="{{ item.avatarUrl }}" mode="aspectFill" />
          <text wx:else class="avatar-fallback">{{ item.is_anonymous ? '匿' : '实' }}</text>
        </view>
        <text class="card-author">{{ item.displayName }}</text>
      </view>
      <text class="card-text">{{ item.content }}</text>
      <view wx:if="{{ item.imageUrl }}" class="card-pic-wrap">
        <image
          class="card-pic"
          src="{{ item.imageUrl }}"
          mode="aspectFill"
          data-url="{{ item.imageUrl }}"
          catch:tap="onPreviewImage"
        />
      </view>
      <view class="card-footer">
        <text class="card-time">{{ item.timeText }}</text>
        <view class="card-footer-actions">
          <view class="like-wrap" data-id="{{ item._id }}" catch:tap="onLikeTap">
            <van-icon name="good-job-o" size="40rpx" color="#646566" />
            <text class="like-num">{{ item.likes }}</text>
          </view>
          <view class="delete-wrap" data-id="{{ item._id }}" catch:tap="onDeleteTap">
            <van-icon name="delete" size="36rpx" color="#c8c9cc" />
            <text class="delete-text">删除</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
