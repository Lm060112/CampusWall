<view class="page">
  <view class="header">
    <view class="back-btn" catch:tap="onBack"><van-icon name="arrow-left" size="38rpx" color="#111" /></view>
    <text class="header-title">领券中心</text>
    <view class="header-placeholder"></view>
  </view>
  <view class="tabs">
    <view wx:for="{{ tabs }}" wx:key="key" class="tab {{ activeTab === item.key ? 'tab--active' : '' }}" data-key="{{ item.key }}" catch:tap="onTabTap">{{ item.title }}</view>
  </view>
  <view wx:if="{{ !coupons.length }}" class="empty">暂无优惠券</view>
  <view wx:for="{{ coupons }}" wx:key="id" class="coupon-card coupon-card--{{ item.status }}">
    <view class="amount">{{ item.amount }}</view>
    <view class="coupon-main">
      <text class="coupon-title">{{ item.title }}</text>
      <text class="coupon-desc">{{ item.desc }}</text>
    </view>
    <view wx:if="{{ item.status === 'available' }}" class="claim-btn" data-id="{{ item.id }}" catch:tap="onClaimTap">领取</view>
    <view wx:else class="status-text">{{ item.status === 'claimed' ? '已领取' : '已使用' }}</view>
  </view>
</view>
