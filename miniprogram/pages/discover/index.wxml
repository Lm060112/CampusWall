<view class="page">
  <scroll-view class="feed-scroll" scroll-y enable-back-to-top>
    <view class="feed-inner {{ fileList.length ? 'feed-inner--thumb' : '' }}">
      <view class="hot-card">
        <view class="hot-header">
          <view class="hot-header-left">
            <van-icon name="fire" size="36rpx" color="#ff6a00" />
            <text class="hot-header-title">校园热搜</text>
          </view>
          <text class="hot-header-link" catch:tap="onHotBriefTap">热搜简报 ></text>
        </view>
        <view class="hot-grid">
          <view class="hot-col">
            <view
              wx:for="{{ hotLeft }}"
              wx:key="id"
              class="hot-item {{ filterKeyword === item.title ? 'hot-item--active' : '' }}"
              data-title="{{ item.title }}"
              catch:tap="onHotTap"
            >
              <text class="hot-item-text">{{ item.title }}</text>
              <text wx:if="{{ item.tag }}" class="hot-tag hot-tag--{{ item.tagType }}">{{ item.tag }}</text>
            </view>
          </view>
          <view class="hot-col">
            <view
              wx:for="{{ hotRight }}"
              wx:key="id"
              class="hot-item {{ filterKeyword === item.title ? 'hot-item--active' : '' }}"
              data-title="{{ item.title }}"
              catch:tap="onHotTap"
            >
              <text class="hot-item-text">{{ item.title }}</text>
              <text wx:if="{{ item.tag }}" class="hot-tag hot-tag--{{ item.tagType }}">{{ item.tag }}</text>
            </view>
          </view>
        </view>
        <view class="hot-more" catch:tap="onHotMoreTap">更多热搜 ></view>
      </view>

      <view class="section-header">
        <view class="section-title">
          最新动态
          <text wx:if="{{ filterKeyword }}" class="filter-hint">· {{ filterKeyword }}</text>
        </view>
        <text wx:if="{{ filterKeyword }}" class="filter-clear" catch:tap="onClearFilter">取消筛选</text>
      </view>
      <view wx:if="{{ !loading && !filterKeyword && posts.length === 0 }}" class="empty">暂无帖子，来发第一条吧</view>
      <view wx:if="{{ !loading && filterKeyword && posts.length === 0 }}" class="empty">
        暂无「{{ filterKeyword }}」相关帖子，快来发第一条吧
      </view>
      <view wx:for="{{ posts }}" wx:key="_id" class="card">
        <view class="card-meta">
          <view class="avatar">
            <image wx:if="{{ item.avatarUrl }}" class="avatar-img" src="{{ item.avatarUrl }}" mode="aspectFill" />
            <text wx:else class="avatar-fallback">{{ item.displayName[0] }}</text>
          </view>
          <text class="card-author">{{ item.displayName }}</text>
        </view>
        <text class="card-text">{{ item.content }}</text>
        <view wx:if="{{ item.imageUrl }}" class="card-pic-wrap">
          <image
            class="card-pic"
            src="{{ item.imageUrl }}"
            mode="aspectFill"
            data-url="{{ item.imageUrl }}"
            catch:tap="onPreviewImage"
          />
        </view>
        <view class="card-footer">
          <text class="card-time">{{ item.timeText }}</text>
          <view class="card-footer-actions">
            <view class="comment-wrap" data-id="{{ item._id }}" catch:tap="onShowCommentInput">
              <van-icon name="comment-o" size="40rpx" color="#646566" />
              <text class="comment-num">{{ item.comments.length || 0 }}</text>
            </view>
            <view class="like-wrap {{ item.isLiked ? 'like-wrap--active' : '' }}" data-id="{{ item._id }}" catch:tap="onLikeTap">
              <van-icon name="{{ item.isLiked ? 'good-job' : 'good-job-o' }}" size="40rpx" color="{{ item.isLiked ? '#1989fa' : '#646566' }}" />
              <text class="like-num {{ item.isLiked ? 'like-num--active' : '' }}">{{ item.likes }}</text>
            </view>
            <view class="delete-wrap" data-id="{{ item._id }}" catch:tap="onDeleteTap">
              <van-icon name="delete" size="36rpx" color="#c8c9cc" />
              <text class="delete-text">删除</text>
            </view>
          </view>
        </view>

        <!-- 评论列表 -->
        <view class="comment-section" wx:if="{{ item.comments && item.comments.length > 0 }}">
          <view wx:for="{{ item.comments }}" wx:for-item="comment" wx:key="_id" class="comment-item">
            <view class="comment-content">
              <text class="comment-author">{{ comment.nickname }}: </text>
              <text class="comment-text">{{ comment.content }}</text>
            </view>
            <view class="comment-footer">
              <text class="comment-time">{{ comment.timeText }}</text>
              <view class="comment-actions">
                <view class="comment-like" data-id="{{ comment._id }}" catch:tap="onLikeCommentTap">
                  <van-icon name="{{ comment.isLiked ? 'good-job' : 'good-job-o' }}" size="32rpx" color="{{ comment.isLiked ? '#1989fa' : '#969799' }}" />
                  <text class="comment-like-num {{ comment.isLiked ? 'comment-like-num--active' : '' }}">{{ comment.likes || 0 }}</text>
                </view>
                <view class="comment-delete" data-id="{{ comment._id }}" catch:tap="onDeleteCommentTap" wx:if="{{ comment._openid === openid }}">
                  <text>删除</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 评论输入弹窗 -->
  <view class="comment-input-overlay" wx:if="{{ activePostId }}" catch:tap="onHideCommentInput">
    <view class="comment-input-bar" catch:tap="stopBubble">
      <input
        class="c-input"
        placeholder="写下你的评论..."
        focus="{{ !!activePostId }}"
        bindinput="onCommentInput"
        value="{{ commentInput }}"
        confirm-type="send"
        bindconfirm="onPublishComment"
      />
      <view class="c-send-btn {{ !commentInput.trim() ? 'c-send-btn--disabled' : '' }}" catch:tap="onPublishComment">发送</view>
    </view>
  </view>

  <view class="post-bar">
    <view wx:if="{{ fileList.length }}" class="post-thumb-row">
      <image class="post-thumb" src="{{ fileList[0].url }}" mode="aspectFill" />
      <view class="post-thumb-del" catch:tap="onRemoveImage">
        <van-icon name="cross" size="28rpx" color="#fff" />
      </view>
    </view>
    <view class="post-input-row">
      <view class="post-icon-btn" catch:tap="onChooseImage">
        <van-icon name="photo-o" size="44rpx" color="#646566" />
      </view>
      <view class="search-input-wrap">
        <input
          class="search-input"
          model:value="{{ content }}"
          placeholder="分享你的新鲜事..."
          placeholder-class="search-placeholder"
          confirm-type="send"
          bindinput="onContentInput"
          bindconfirm="onPublish"
        />
      </view>
      <view class="send-btn {{ publishing ? 'send-btn--disabled' : '' }}" catch:tap="onPublish">
        {{ publishing ? '发布中' : '发布' }}
      </view>
    </view>
  </view>
</view>
