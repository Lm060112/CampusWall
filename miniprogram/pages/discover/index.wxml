<view class="page">
  <view class="top-row">
    <text class="page-title">发现</text>
    <view class="search-box" catch:tap="onSearchTap">
      <van-icon name="search" size="36rpx" color="#7a7e83" />
      <text>搜索帖子 / 用户 / 话题</text>
    </view>
    <view class="scan-btn" catch:tap="onScanTap">
      <van-icon name="scan" size="42rpx" color="#111" />
    </view>
  </view>

  <view class="tabs">
    <view
      wx:for="{{ tabs }}"
      wx:key="*this"
      class="tab {{ activeTab === item ? 'tab--active' : '' }}"
      data-tab="{{ item }}"
      catch:tap="onTabTap"
    >
      {{ item }}
    </view>
  </view>

  <scroll-view class="feed-scroll" scroll-y enhanced show-scrollbar="{{ false }}">
    <view class="feed-list">
      <view wx:if="{{ loading }}" class="empty-state">加载中...</view>
      <view wx:if="{{ !loading && feedList.length === 0 }}" class="empty-state">暂无内容，来发布第一条吧</view>

      <view wx:for="{{ feedList }}" wx:key="id" class="feed-card">
        <view class="feed-header">
          <image class="avatar" src="{{ item.avatar }}" mode="aspectFill" />
          <view class="author-main">
            <view class="author-row">
              <text class="author-name">{{ item.author }}</text>
              <text class="tag tag--{{ item.tagClass }}">{{ item.tag }}</text>
            </view>
            <text class="feed-meta">{{ item.time }} · {{ item.topic }}</text>
          </view>
          <view wx:if="{{ item.canDelete }}" class="delete-link" data-id="{{ item.id }}" catch:tap="onDeletePost">删除</view>
        </view>

        <view class="feed-content">
          <text>{{ item.content }}</text>
          <text wx:if="{{ item.priceText }}" class="price-inline">{{ item.priceText }}</text>
        </view>

        <view wx:if="{{ item.images && item.images.length }}" class="image-grid image-grid--{{ item.imageClass }}">
          <image
            wx:for="{{ item.images }}"
            wx:for-item="img"
            wx:key="*this"
            class="feed-image"
            src="{{ img }}"
            mode="aspectFill"
          />
        </view>

        <view class="feed-footer">
          <view class="location">
            <van-icon name="location" size="30rpx" color="#18b957" />
            <text>{{ item.location }}</text>
          </view>
          <view class="actions">
            <view class="action {{ item.isLiked ? 'action--liked' : '' }}" data-id="{{ item.id }}" catch:tap="onLikeTap">
              <van-icon name="{{ item.isLiked ? 'like' : 'like-o' }}" size="40rpx" color="{{ item.isLiked ? '#12b85b' : '#333' }}" />
              <text>{{ item.likes }}</text>
            </view>
            <view class="action" data-id="{{ item.id }}" catch:tap="onShowCommentInput">
              <van-icon name="comment-o" size="40rpx" color="#333" />
              <text>{{ item.commentCount }}</text>
            </view>
          </view>
        </view>

        <view wx:if="{{ item.comments && item.comments.length }}" class="comment-list">
          <view wx:for="{{ item.comments }}" wx:for-item="comment" wx:key="_id" class="comment-row">
            <text class="comment-author">{{ comment.nickname }}：</text>
            <text class="comment-content">{{ comment.content }}</text>
            <text wx:if="{{ comment.canDelete }}" class="comment-delete" data-id="{{ comment._id }}" catch:tap="onDeleteComment">删除</text>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="publish-fab" catch:tap="onPublishTap">
    <van-icon name="edit" size="44rpx" color="#fff" />
    <text>发布</text>
  </view>

  <view wx:if="{{ showComposer }}" class="overlay" catch:tap="onCloseComposer">
    <view class="composer" catch:tap="stopBubble">
      <view class="composer-head">
        <text>发布动态</text>
        <van-icon name="cross" size="34rpx" color="#777" catch:tap="onCloseComposer" />
      </view>
      <view class="category-row">
        <view
          wx:for="{{ categoryOptions }}"
          wx:key="*this"
          class="category-chip {{ draftCategory === item ? 'category-chip--active' : '' }}"
          data-category="{{ item }}"
          catch:tap="onCategoryTap"
        >
          {{ item }}
        </view>
      </view>
      <textarea
        class="composer-textarea"
        value="{{ draftContent }}"
        maxlength="300"
        placeholder="分享校园新鲜事..."
        bindinput="onDraftInput"
      />
      <input
        class="location-input"
        value="{{ draftLocation }}"
        placeholder="地点，如 崇明校区 · 一食堂"
        bindinput="onLocationInput"
      />
      <view class="draft-images">
        <view wx:for="{{ draftImages }}" wx:key="url" class="draft-image-wrap">
          <image class="draft-image" src="{{ item.url }}" mode="aspectFill" />
          <view class="draft-image-remove" data-index="{{ index }}" catch:tap="onRemoveDraftImage">
            <van-icon name="cross" size="22rpx" color="#fff" />
          </view>
        </view>
        <view wx:if="{{ draftImages.length < 3 }}" class="image-picker" catch:tap="onChooseImage">
          <van-icon name="photo-o" size="42rpx" color="#8a8f98" />
          <text>图片</text>
        </view>
      </view>
      <button class="submit-btn" loading="{{ publishing }}" bindtap="onSubmitPost">发布</button>
    </view>
  </view>

  <view class="comment-input-overlay" wx:if="{{ activePostId }}" catch:tap="onHideCommentInput">
    <view class="comment-input-bar" catch:tap="stopBubble">
      <input
        class="comment-input"
        placeholder="写下你的评论..."
        focus="{{ !!activePostId }}"
        bindinput="onCommentInput"
        value="{{ commentInput }}"
        confirm-type="send"
        bindconfirm="onSubmitComment"
      />
      <view class="comment-send" catch:tap="onSubmitComment">发送</view>
    </view>
  </view>
</view>
