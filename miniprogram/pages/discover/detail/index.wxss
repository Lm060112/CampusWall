.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 130rpx;
  box-sizing: border-box;
  background: #fbfbfb;
}

.header {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.back-btn,
.header-placeholder {
  width: 68rpx;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-title {
  flex: 1;
  text-align: center;
  color: #111;
  font-size: 34rpx;
  font-weight: 900;
}

.post-card,
.comment-panel {
  margin-top: 20rpx;
  padding: 26rpx;
  border: 1rpx solid #edf0f3;
  border-radius: 8rpx;
  background: #fff;
}

.author-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.avatar {
  width: 86rpx;
  height: 86rpx;
  border-radius: 43rpx;
  background: #f0f2f5;
}

.author-main {
  flex: 1;
  min-width: 0;
}

.author-name {
  display: block;
  color: #111;
  font-size: 31rpx;
  font-weight: 900;
}

.meta {
  display: block;
  margin-top: 8rpx;
  color: #777;
  font-size: 24rpx;
}

.tag {
  padding: 8rpx 14rpx;
  color: #148844;
  font-size: 23rpx;
  border-radius: 6rpx;
  background: #e7f7ec;
}

.content {
  display: block;
  margin-top: 28rpx;
  color: #111;
  font-size: 31rpx;
  line-height: 1.7;
}

.price {
  display: block;
  margin-top: 12rpx;
  color: #f0442e;
  font-size: 34rpx;
  font-weight: 900;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 24rpx;
}

.post-image {
  width: 100%;
  height: 170rpx;
  border-radius: 8rpx;
  background: #f0f2f5;
}

.event-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 22rpx;
  padding: 18rpx;
  border-radius: 8rpx;
  background: #eef9ef;
}

.event-title {
  display: block;
  color: #148844;
  font-size: 28rpx;
  font-weight: 800;
}

.event-time {
  display: block;
  margin-top: 6rpx;
  color: #667085;
  font-size: 23rpx;
}

.location {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 24rpx;
  color: #666;
  font-size: 25rpx;
}

.action-row {
  display: flex;
  align-items: center;
  gap: 36rpx;
  margin-top: 28rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid #edf0f3;
}

.action {
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: #333;
  font-size: 27rpx;
}

.action--active {
  color: #12b85b;
}

.section-title {
  display: block;
  color: #111;
  font-size: 31rpx;
  font-weight: 900;
}

.empty {
  padding: 36rpx 0;
  color: #8a8f98;
  font-size: 26rpx;
  text-align: center;
}

.comment-row {
  display: flex;
  gap: 18rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #edf0f3;
}

.comment-row:last-child {
  border-bottom: none;
}

.comment-avatar {
  width: 62rpx;
  height: 62rpx;
  border-radius: 31rpx;
  background: #f0f2f5;
}

.comment-main {
  flex: 1;
  min-width: 0;
}

.comment-author {
  display: block;
  color: #111;
  font-size: 26rpx;
  font-weight: 800;
}

.comment-content {
  display: block;
  margin-top: 8rpx;
  color: #555;
  font-size: 26rpx;
  line-height: 1.5;
}

.comment-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 24rpx 32rpx;
  box-sizing: border-box;
  background: #fff;
  box-shadow: 0 -8rpx 24rpx rgba(20, 25, 30, 0.06);
}

.comment-input {
  flex: 1;
  height: 72rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  border-radius: 8rpx;
  background: #f1f3f5;
}

.send-btn {
  width: 96rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  color: #fff;
  font-size: 26rpx;
  border-radius: 8rpx;
  background: #12b85b;
}
