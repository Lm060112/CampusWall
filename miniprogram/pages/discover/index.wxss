.page {
  position: relative;
  min-height: 100vh;
  padding: 30rpx 28rpx 0;
  box-sizing: border-box;
  background: #fbfbfb;
}

.top-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.page-title {
  color: #111;
  font-size: 46rpx;
  font-weight: 900;
}

.search-box {
  flex: 1;
  height: 70rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  border: 1rpx solid #e1e5ea;
  border-radius: 8rpx;
  color: #8a8f98;
  font-size: 28rpx;
  background: #fff;
}

.scan-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tabs {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 34rpx;
  padding: 0 8rpx;
  border-bottom: 1rpx solid #edf0f3;
}

.tab {
  position: relative;
  padding-bottom: 20rpx;
  color: #777;
  font-size: 32rpx;
  font-weight: 500;
}

.tab--active {
  color: #111;
  font-weight: 900;
}

.tab--active::after {
  content: "";
  position: absolute;
  left: 8rpx;
  right: 8rpx;
  bottom: 0;
  height: 6rpx;
  border-radius: 3rpx;
  background: #12b85b;
}

.feed-scroll {
  height: calc(100vh - 164rpx);
}

.feed-list {
  padding: 18rpx 0 150rpx;
}

.empty-state {
  padding: 90rpx 0;
  color: #8a8f98;
  font-size: 28rpx;
  text-align: center;
}

.feed-card {
  margin-bottom: 18rpx;
  padding: 24rpx;
  border: 1rpx solid #edf0f3;
  border-radius: 8rpx;
  background: #fff;
}

.feed-header {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.avatar {
  width: 82rpx;
  height: 82rpx;
  border-radius: 41rpx;
  background: #f0f2f5;
}

.author-main {
  flex: 1;
  min-width: 0;
}

.author-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.author-name {
  color: #111;
  font-size: 31rpx;
  font-weight: 800;
}

.feed-meta {
  display: block;
  margin-top: 8rpx;
  color: #777;
  font-size: 24rpx;
}

.delete-link {
  padding: 8rpx 12rpx;
  color: #999;
  font-size: 24rpx;
}

.tag {
  padding: 6rpx 12rpx;
  font-size: 23rpx;
  border-radius: 6rpx;
}

.tag--idle {
  color: #15954d;
  background: #e7f7ec;
}

.tag--help,
.tag--carpool {
  color: #246fe5;
  background: #eaf2ff;
}

.tag--activity {
  color: #f08a12;
  background: #fff3df;
}

.tag--latest,
.tag--recommend {
  color: #666;
  background: #f1f3f5;
}

.feed-content {
  margin: 24rpx 0 18rpx 100rpx;
  color: #111;
  font-size: 29rpx;
  line-height: 1.65;
}

.price-inline {
  color: #f0442e;
}

.image-grid {
  display: grid;
  gap: 12rpx;
  margin-left: 100rpx;
}

.image-grid--1 {
  grid-template-columns: 240rpx;
}

.image-grid--2 {
  grid-template-columns: repeat(2, 1fr);
}

.image-grid--3 {
  grid-template-columns: repeat(3, 1fr);
}

.feed-image {
  width: 100%;
  height: 150rpx;
  border-radius: 8rpx;
  background: #f0f2f5;
}

.image-grid--1 .feed-image {
  height: 150rpx;
}

.event-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin: 18rpx 0 0 100rpx;
  padding: 16rpx 18rpx;
  border-radius: 8rpx;
  background: #eef9ef;
}

.event-main {
  flex: 1;
  min-width: 0;
}

.event-title {
  display: block;
  color: #148844;
  font-size: 27rpx;
  font-weight: 800;
}

.event-time {
  display: block;
  margin-top: 6rpx;
  color: #667085;
  font-size: 22rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.event-btn {
  width: 116rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  color: #fff;
  font-size: 23rpx;
  border-radius: 8rpx;
  background: #14a957;
}

.feed-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin: 20rpx 0 0 100rpx;
}

.location {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #777;
  font-size: 24rpx;
}

.location text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.actions {
  display: flex;
  align-items: center;
  gap: 34rpx;
}

.action {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #333;
  font-size: 25rpx;
}

.action--liked {
  color: #12b85b;
}

.comment-list {
  margin: 20rpx 0 0 100rpx;
  padding: 14rpx 16rpx;
  border-radius: 8rpx;
  background: #f7f8fa;
}

.comment-row {
  display: flex;
  align-items: center;
  min-height: 42rpx;
  color: #555;
  font-size: 24rpx;
}

.comment-author {
  color: #111;
  font-weight: 700;
}

.comment-content {
  flex: 1;
  min-width: 0;
}

.comment-delete {
  padding-left: 16rpx;
  color: #999;
}

.publish-fab {
  position: fixed;
  right: 36rpx;
  bottom: 128rpx;
  width: 126rpx;
  height: 126rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  font-weight: 800;
  border-radius: 63rpx;
  background: #12b85b;
  box-shadow: 0 12rpx 28rpx rgba(18, 184, 91, 0.35);
}

.overlay {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  align-items: flex-end;
  background: rgba(0, 0, 0, 0.35);
}

.composer {
  width: 100%;
  padding: 28rpx;
  box-sizing: border-box;
  border-radius: 18rpx 18rpx 0 0;
  background: #fff;
}

.composer-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #111;
  font-size: 32rpx;
  font-weight: 900;
}

.category-row {
  display: flex;
  gap: 14rpx;
  margin-top: 24rpx;
}

.category-chip {
  padding: 10rpx 20rpx;
  color: #666;
  font-size: 25rpx;
  border-radius: 8rpx;
  background: #f1f3f5;
}

.category-chip--active {
  color: #148844;
  background: #e7f7ec;
}

.composer-textarea {
  width: 100%;
  height: 180rpx;
  margin-top: 22rpx;
  padding: 18rpx;
  box-sizing: border-box;
  color: #111;
  font-size: 28rpx;
  border-radius: 8rpx;
  background: #f7f8fa;
}

.location-input {
  height: 76rpx;
  margin-top: 18rpx;
  padding: 0 18rpx;
  box-sizing: border-box;
  color: #111;
  font-size: 26rpx;
  border-radius: 8rpx;
  background: #f7f8fa;
}

.draft-images {
  display: flex;
  gap: 14rpx;
  margin-top: 18rpx;
}

.draft-image-wrap,
.image-picker {
  position: relative;
  width: 130rpx;
  height: 130rpx;
  border-radius: 8rpx;
  background: #f1f3f5;
}

.draft-image {
  width: 130rpx;
  height: 130rpx;
  border-radius: 8rpx;
}

.draft-image-remove {
  position: absolute;
  right: -8rpx;
  top: -8rpx;
  width: 34rpx;
  height: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 17rpx;
  background: rgba(0, 0, 0, 0.65);
}

.image-picker {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  color: #8a8f98;
  font-size: 24rpx;
}

.submit-btn {
  height: 84rpx;
  line-height: 84rpx;
  margin-top: 26rpx;
  color: #fff;
  font-size: 30rpx;
  border-radius: 8rpx;
  background: #12b85b;
}

.comment-input-overlay {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 30;
  display: flex;
  align-items: flex-end;
  background: rgba(0, 0, 0, 0.18);
}

.comment-input-bar {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 24rpx 32rpx;
  box-sizing: border-box;
  background: #fff;
}

.comment-input {
  flex: 1;
  height: 72rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  border-radius: 8rpx;
  background: #f1f3f5;
}

.comment-send {
  width: 92rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  color: #fff;
  font-size: 26rpx;
  border-radius: 8rpx;
  background: #12b85b;
}
