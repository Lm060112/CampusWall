<view class="page">
  <view class="header">
    <view class="back-btn" catch:tap="onBack"><van-icon name="arrow-left" size="38rpx" color="#111" /></view>
    <view class="header-main">
      <text class="title">周边玩乐</text>
      <text class="subtitle">活动、运动、桌游和探店预约</text>
    </view>
  </view>

  <view class="hero">
    <view>
      <text class="hero-title">发现校园周边好去处</text>
      <text class="hero-desc">先做预约闭环，后续可接真实活动名额、商家核销和评价。</text>
    </view>
    <van-icon name="photograph" size="78rpx" color="#8b62f2" />
  </view>

  <view class="activity-list">
    <view wx:for="{{ activities }}" wx:key="id" class="activity-card" data-id="{{ item.id }}" catch:tap="onActivityTap">
      <image class="activity-img" src="/images/default-goods-image.png" mode="aspectFill" />
      <view class="activity-main">
        <view class="activity-head">
          <text class="activity-name">{{ item.name }}</text>
          <text class="rating">★ {{ item.rating }}</text>
        </view>
        <text class="desc">{{ item.desc }}</text>
        <view class="info-row">
          <van-icon name="location-o" size="24rpx" color="#8b62f2" />
          <text>{{ item.location }}</text>
        </view>
        <view class="info-row">
          <van-icon name="clock-o" size="24rpx" color="#8b62f2" />
          <text>{{ item.time }}</text>
        </view>
        <view class="bottom-row">
          <text class="price">¥{{ item.price / 100 }}</text>
          <text class="tag">{{ item.tag }}</text>
          <view class="reserve-btn" data-id="{{ item.id }}" catch:tap="onReserveTap">预约</view>
        </view>
      </view>
    </view>
  </view>
</view>
