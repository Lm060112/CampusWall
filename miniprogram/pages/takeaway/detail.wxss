.page { min-height: 100vh; padding: 28rpx 28rpx 140rpx; box-sizing: border-box; background: #fbfbfb; }
.header { display: flex; align-items: center; gap: 16rpx; }
.back-btn, .header-placeholder { width: 68rpx; height: 68rpx; display: flex; align-items: center; justify-content: center; }
.header-title { flex: 1; text-align: center; color: #111; font-size: 36rpx; font-weight: 900; }
.merchant-card { display: flex; gap: 20rpx; margin-top: 22rpx; padding: 22rpx; border-radius: 8rpx; background: linear-gradient(135deg, #fff4e8, #fff); box-shadow: 0 8rpx 24rpx rgba(38,47,56,.05); }
.merchant-img { width: 130rpx; height: 130rpx; border-radius: 8rpx; background: #eef2f5; }
.merchant-main { flex: 1; min-width: 0; }
.merchant-name { display: block; color: #111; font-size: 34rpx; font-weight: 900; }
.merchant-meta { display: block; margin-top: 10rpx; color: #5f6872; font-size: 24rpx; }
.tag-row { display: flex; flex-wrap: wrap; gap: 8rpx; margin-top: 12rpx; }
.tag { padding: 5rpx 10rpx; border-radius: 6rpx; color: #e35d25; font-size: 22rpx; background: #fff0e8; }
.shop-body { display: flex; gap: 18rpx; margin-top: 22rpx; height: calc(100vh - 360rpx); min-height: 560rpx; }
.category-list { width: 150rpx; flex: 0 0 150rpx; border-radius: 8rpx; background: #f1f3f5; }
.category-item { min-height: 84rpx; display: flex; align-items: center; justify-content: center; color: #59616b; font-size: 25rpx; }
.category-item--active { color: #f08a1f; font-weight: 900; background: #fff; }
.product-list { flex: 1; min-width: 0; }
.product-card { display: flex; gap: 16rpx; padding: 18rpx 0; border-bottom: 1rpx solid #edf0f2; }
.product-img { width: 126rpx; height: 126rpx; border-radius: 8rpx; background: #eef2f5; }
.product-main { flex: 1; min-width: 0; }
.product-name { display: block; color: #111; font-size: 29rpx; font-weight: 900; }
.product-desc, .product-sales { display: block; margin-top: 8rpx; color: #7a828c; font-size: 23rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.product-bottom, .stepper { display: flex; align-items: center; }
.product-bottom { justify-content: space-between; margin-top: 12rpx; }
.product-price { color: #f0442e; font-size: 31rpx; font-weight: 900; }
.stepper { gap: 12rpx; }
.step-btn { width: 44rpx; height: 44rpx; display: flex; align-items: center; justify-content: center; border: 1rpx solid #f08a1f; border-radius: 22rpx; background: #fff; }
.step-btn--add { background: #f08a1f; }
.step-count { min-width: 28rpx; text-align: center; color: #111; font-size: 26rpx; }
.cart-bar { position: fixed; left: 28rpx; right: 28rpx; bottom: 34rpx; height: 96rpx; display: flex; align-items: center; gap: 18rpx; padding: 0 18rpx; box-sizing: border-box; border-radius: 48rpx; background: #1f2933; box-shadow: 0 14rpx 34rpx rgba(20,25,30,.22); }
.cart-icon { position: relative; width: 64rpx; height: 64rpx; display: flex; align-items: center; justify-content: center; border-radius: 32rpx; background: #f08a1f; }
.cart-count { position: absolute; right: -8rpx; top: -10rpx; min-width: 30rpx; height: 30rpx; line-height: 30rpx; text-align: center; color: #fff; font-size: 20rpx; border-radius: 15rpx; background: #ff4d4f; }
.cart-main { flex: 1; min-width: 0; }
.cart-price { display: block; color: #fff; font-size: 31rpx; font-weight: 900; }
.cart-tip { display: block; margin-top: 4rpx; color: #aeb6c2; font-size: 21rpx; }
.checkout-btn { width: 140rpx; height: 62rpx; line-height: 62rpx; text-align: center; color: #fff; font-size: 27rpx; font-weight: 800; border-radius: 31rpx; background: #f08a1f; }
.checkout-btn--disabled { color: #d2d6dc; background: #56616f; }
