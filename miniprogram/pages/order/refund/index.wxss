.page { min-height: 100vh; padding: 28rpx; box-sizing: border-box; background: #fbfbfb; }
.header { display: flex; align-items: center; gap: 16rpx; }
.back-btn,.header-placeholder { width: 68rpx; height: 68rpx; display: flex; align-items: center; justify-content: center; }
.header-title { flex: 1; text-align: center; color: #111; font-size: 36rpx; font-weight: 900; }
.order-card,.panel { margin-top: 22rpx; padding: 24rpx; border-radius: 8rpx; border: 1rpx solid #edf0f2; background: #fff; }
.merchant { display: block; color: #111; font-size: 31rpx; font-weight: 900; }
.amount { display: block; margin-top: 10rpx; color: #777; font-size: 25rpx; }
.panel-title { display: block; color: #111; font-size: 30rpx; font-weight: 900; }
.reason-list { display: flex; flex-wrap: wrap; gap: 14rpx; margin-top: 20rpx; }
.reason { padding: 12rpx 18rpx; border-radius: 8rpx; color: #555; font-size: 25rpx; background: #f1f3f5; }
.reason--active { color: #148844; font-weight: 800; background: #e7f7ec; }
.textarea { width: 100%; height: 170rpx; margin-top: 22rpx; padding: 18rpx; box-sizing: border-box; color: #111; font-size: 27rpx; border-radius: 8rpx; background: #f7f8fa; }
.proof-title { margin-top: 24rpx; color: #111; font-size: 28rpx; font-weight: 900; }
.image-grid { display: flex; flex-wrap: wrap; gap: 16rpx; margin-top: 16rpx; }
.image-item,.image-picker { position: relative; width: 150rpx; height: 150rpx; border-radius: 8rpx; overflow: hidden; }
.proof-img { width: 100%; height: 100%; }
.remove-img { position: absolute; top: 8rpx; right: 8rpx; width: 36rpx; height: 36rpx; display: flex; align-items: center; justify-content: center; border-radius: 18rpx; background: rgba(0, 0, 0, 0.55); }
.image-picker { display: flex; align-items: center; justify-content: center; flex-direction: column; gap: 8rpx; color: #8a9099; font-size: 24rpx; background: #f7f8fa; border: 1rpx dashed #d8dde3; box-sizing: border-box; }
.submit-btn { position: fixed; left: 28rpx; right: 28rpx; bottom: 34rpx; height: 84rpx; line-height: 84rpx; text-align: center; color: #fff; font-size: 30rpx; font-weight: 900; border-radius: 42rpx; background: #12b85b; }
.empty { margin-top: 80rpx; text-align: center; color: #8a9099; font-size: 28rpx; }
