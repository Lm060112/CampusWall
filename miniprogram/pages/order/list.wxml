<view class="page">
  <view class="header">
    <view class="back-btn" catch:tap="onBack">
      <van-icon name="arrow-left" size="38rpx" color="#111" />
    </view>
    <text class="header-title">我的订单</text>
    <view class="clear-btn" catch:tap="onClearTap">清空</view>
  </view>

  <view class="filter-row">
    <view
      wx:for="{{ filters }}"
      wx:key="key"
      class="filter-item {{ activeFilter === item.key ? 'filter-item--active' : '' }}"
      data-key="{{ item.key }}"
      catch:tap="onFilterTap"
    >
      {{ item.title }}
    </view>
  </view>

  <view wx:if="{{ visibleOrders.length }}" class="order-list">
    <view wx:for="{{ visibleOrders }}" wx:key="id" class="order-card" data-id="{{ item.id }}" catch:tap="onOrderTap">
      <view class="order-head">
        <view>
          <text class="merchant-name">{{ item.merchant.name }}</text>
          <text class="order-time">{{ item.timeText }} · 取餐号 {{ item.pickupNo }}</text>
        </view>
        <text class="status {{ item.status === '已完成' ? 'status--done' : 'status--doing' }}">{{ item.status }}</text>
      </view>

      <view class="order-body">
        <text class="preview">{{ item.previewText }}</text>
        <text class="pickup">{{ item.pickupType }} · {{ item.merchant.eta }}</text>
        <text wx:if="{{ item.remark }}" class="remark">备注：{{ item.remark }}</text>
      </view>

      <view class="order-bottom">
        <text class="summary">共 {{ item.itemCount }} 件</text>
        <text class="amount">¥{{ item.totalAmount / 100 }}</text>
        <view
          wx:if="{{ item.status !== '已完成' }}"
          class="complete-btn"
          data-id="{{ item.id }}"
          catchtap="onCompleteTap"
        >
          确认取餐
        </view>
      </view>
    </view>
  </view>

  <view wx:else class="empty">
    <van-icon name="orders-o" size="96rpx" color="#b7c0ca" />
    <text class="empty-title">暂无订单</text>
    <text class="empty-desc">从校内点单提交订单后，会显示在这里。</text>
  </view>
</view>
