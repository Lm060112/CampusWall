.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 150rpx;
  box-sizing: border-box;
  background: #fbfbfb;
}

.header {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.back-btn,
.header-placeholder {
  width: 68rpx;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-title {
  flex: 1;
  text-align: center;
  color: #111;
  font-size: 36rpx;
  font-weight: 800;
}

.status-card,
.pickup-card,
.order-card {
  margin-top: 22rpx;
  padding: 26rpx;
  border: 1rpx solid #edf0f2;
  border-radius: 8rpx;
  background: #fff;
  box-shadow: 0 8rpx 24rpx rgba(38, 47, 56, 0.05);
}

.status-card {
  background: linear-gradient(135deg, #edf9f0, #fff7ea);
}

.status-title {
  display: block;
  color: #111;
  font-size: 40rpx;
  font-weight: 900;
}

.status-desc {
  display: block;
  margin-top: 8rpx;
  color: #5c6670;
  font-size: 26rpx;
}

.step-row {
  display: flex;
  align-items: center;
  margin-top: 28rpx;
}

.step-item {
  width: 112rpx;
  display: flex;
  align-items: center;
  flex-direction: column;
  gap: 8rpx;
  color: #9aa3ad;
  font-size: 22rpx;
}

.step-item--active {
  color: #0b9b4b;
  font-weight: 700;
}

.step-dot {
  width: 22rpx;
  height: 22rpx;
  border-radius: 11rpx;
  background: currentColor;
}

.step-line {
  flex: 1;
  height: 4rpx;
  margin-bottom: 34rpx;
  background: #dfe4e9;
}

.step-line--active {
  background: #0b9b4b;
}

.pickup-no {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f2f4;
  color: #555d66;
  font-size: 26rpx;
}

.pickup-code {
  color: #111;
  font-size: 48rpx;
  font-weight: 900;
}

.info-row,
.item-row,
.amount-row,
.action-bar {
  display: flex;
  align-items: center;
}

.info-row {
  gap: 22rpx;
  margin-top: 18rpx;
  font-size: 26rpx;
}

.info-label {
  width: 112rpx;
  flex: 0 0 auto;
  color: #8a9099;
}

.info-value {
  flex: 1;
  min-width: 0;
  color: #242a31;
  line-height: 1.35;
}

.card-title {
  color: #111;
  font-size: 31rpx;
  font-weight: 800;
}

.item-row {
  gap: 18rpx;
  margin-top: 24rpx;
}

.item-img {
  width: 108rpx;
  height: 108rpx;
  flex: 0 0 auto;
  border-radius: 8rpx;
  background: #eef2f5;
}

.item-main {
  flex: 1;
  min-width: 0;
}

.item-name {
  display: block;
  color: #111;
  font-size: 28rpx;
  font-weight: 700;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.item-count {
  display: block;
  margin-top: 10rpx;
  color: #8a9099;
  font-size: 24rpx;
}

.item-spec {
  display: block;
  margin-top: 8rpx;
  color: #8a9099;
  font-size: 23rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.item-price {
  color: #111;
  font-size: 27rpx;
  font-weight: 800;
}

.remark-row {
  margin-top: 22rpx;
  padding: 18rpx;
  border-radius: 8rpx;
  color: #5c6670;
  font-size: 25rpx;
  line-height: 1.45;
  background: #f6f8fa;
}

.amount-row {
  justify-content: space-between;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f2f4;
  color: #737b85;
  font-size: 25rpx;
}

.amount {
  color: #f0442e;
  font-size: 34rpx;
  font-weight: 900;
}

.review-stars {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 18rpx;
}

.review-text {
  display: block;
  margin-top: 14rpx;
  color: #444;
  font-size: 26rpx;
  line-height: 1.55;
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 118rpx;
  padding: 16rpx 28rpx 24rpx;
  box-sizing: border-box;
  gap: 14rpx;
  border-top: 1rpx solid #edf0f2;
  background: #fff;
}

.primary-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  color: #fff;
  font-size: 29rpx;
  font-weight: 800;
  border-radius: 36rpx;
  background: #12b85b;
}

.secondary-btn {
  width: 128rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  color: #148844;
  font-size: 27rpx;
  font-weight: 800;
  border: 1rpx solid #bfe8cf;
  border-radius: 36rpx;
  background: #f2fbf5;
}

.empty {
  min-height: 520rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: 16rpx;
  color: #8a9099;
  font-size: 28rpx;
}
