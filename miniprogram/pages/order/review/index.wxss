.page {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
  background: #fbfbfb;
}

.header {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.back-btn,
.header-placeholder {
  width: 68rpx;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-title {
  flex: 1;
  text-align: center;
  color: #111;
  font-size: 36rpx;
  font-weight: 900;
}

.review-card {
  margin-top: 24rpx;
  padding: 30rpx 26rpx;
  border: 1rpx solid #edf0f2;
  border-radius: 8rpx;
  background: #fff;
}

.merchant-name {
  display: block;
  color: #111;
  font-size: 34rpx;
  font-weight: 900;
}

.order-desc {
  display: block;
  margin-top: 10rpx;
  color: #777;
  font-size: 25rpx;
}

.star-row {
  display: flex;
  justify-content: center;
  gap: 18rpx;
  margin-top: 42rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 36rpx;
}

.tag {
  height: 58rpx;
  line-height: 58rpx;
  padding: 0 20rpx;
  color: #555;
  font-size: 25rpx;
  border-radius: 29rpx;
  background: #f1f3f5;
}

.tag--active {
  color: #148844;
  font-weight: 800;
  background: #e7f7ec;
}

.textarea {
  width: 100%;
  height: 180rpx;
  margin-top: 28rpx;
  padding: 18rpx;
  box-sizing: border-box;
  color: #111;
  font-size: 27rpx;
  line-height: 1.5;
  border-radius: 8rpx;
  background: #f7f8fa;
}

.submit-btn {
  height: 82rpx;
  line-height: 82rpx;
  margin-top: 30rpx;
  text-align: center;
  color: #fff;
  font-size: 30rpx;
  font-weight: 900;
  border-radius: 41rpx;
  background: #12b85b;
}

.empty {
  min-height: 520rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: 16rpx;
  color: #8a9099;
  font-size: 28rpx;
}
