.page {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
  background: #fbfbfb;
}

.header {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.back-btn,
.header-placeholder {
  width: 68rpx;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-title {
  flex: 1;
  text-align: center;
  color: #111;
  font-size: 36rpx;
  font-weight: 900;
}

.panel {
  margin-top: 22rpx;
  padding: 0 26rpx;
  border: 1rpx solid #edf0f2;
  border-radius: 8rpx;
  background: #fff;
}

.menu-row {
  min-height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  border-bottom: 1rpx solid #edf0f2;
}

.menu-row:last-child {
  border-bottom: none;
}

.menu-title {
  display: block;
  color: #111;
  font-size: 29rpx;
  font-weight: 800;
}

.menu-desc {
  display: block;
  margin-top: 8rpx;
  color: #777;
  font-size: 24rpx;
}

.about-block {
  padding: 26rpx 0;
}

.about-title {
  display: block;
  color: #111;
  font-size: 30rpx;
  font-weight: 900;
}

.about-desc {
  display: block;
  margin-top: 12rpx;
  color: #555;
  font-size: 25rpx;
  line-height: 1.6;
}

.logout-btn {
  height: 82rpx;
  line-height: 82rpx;
  margin-top: 30rpx;
  text-align: center;
  color: #f0442e;
  font-size: 29rpx;
  font-weight: 900;
  border: 1rpx solid #ffd0c8;
  border-radius: 41rpx;
  background: #fff5f3;
}
