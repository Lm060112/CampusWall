.page { min-height: 100vh; padding: 28rpx 28rpx 130rpx; box-sizing: border-box; background: #fbfbfb; }
.header { display: flex; align-items: center; gap: 16rpx; }
.back-btn,.header-placeholder { width: 68rpx; height: 68rpx; display: flex; align-items: center; justify-content: center; }
.header-title { flex: 1; text-align: center; color: #111; font-size: 36rpx; font-weight: 900; }
.cover { width: 100%; height: 280rpx; margin-top: 22rpx; border-radius: 8rpx; background: #eef2f5; }
.detail-card { margin-top: 18rpx; padding: 26rpx; border-radius: 8rpx; border: 1rpx solid #edf0f2; background: #fff; }
.tag { display: inline-block; padding: 6rpx 12rpx; color: #6f3fd9; font-size: 23rpx; border-radius: 6rpx; background: #f0eaff; }
.title { display: block; margin-top: 18rpx; color: #111; font-size: 38rpx; font-weight: 900; }
.desc { display: block; margin-top: 14rpx; color: #555; font-size: 28rpx; line-height: 1.6; }
.info-row { display: flex; align-items: center; gap: 10rpx; margin-top: 18rpx; color: #555; font-size: 26rpx; }
.section-title { display: block; color: #111; font-size: 31rpx; font-weight: 900; }
.bottom-bar { position: fixed; left: 0; right: 0; bottom: 0; display: flex; align-items: center; gap: 20rpx; padding: 18rpx 28rpx 30rpx; box-sizing: border-box; background: #fff; border-top: 1rpx solid #edf0f2; }
.price { color: #f0442e; font-size: 40rpx; font-weight: 900; }
.reserve-btn { flex: 1; height: 76rpx; line-height: 76rpx; text-align: center; color: #fff; font-size: 29rpx; font-weight: 900; border-radius: 38rpx; background: #8b62f2; }
