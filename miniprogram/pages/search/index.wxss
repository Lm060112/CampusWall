.page { min-height: 100vh; padding: 28rpx; box-sizing: border-box; background: #fbfbfb; }
.search-row { display: flex; align-items: center; gap: 18rpx; }
.search-box { flex: 1; height: 72rpx; display: flex; align-items: center; gap: 12rpx; padding: 0 18rpx; border-radius: 8rpx; background: #fff; border: 1rpx solid #e1e5ea; box-sizing: border-box; }
.search-box input { flex: 1; min-width: 0; font-size: 27rpx; color: #111; }
.tabs { display: flex; gap: 16rpx; margin-top: 24rpx; }
.tab { height: 58rpx; line-height: 58rpx; padding: 0 24rpx; border-radius: 29rpx; color: #606873; font-size: 25rpx; background: #f1f3f5; }
.tab--active { color: #0b8f47; font-weight: 800; background: #e4f7ea; }
.hot-panel { margin-top: 28rpx; padding: 24rpx; border-radius: 8rpx; background: #fff; border: 1rpx solid #edf0f2; }
.section-title { display: block; color: #111; font-size: 30rpx; font-weight: 900; }
.section-row { display: flex; align-items: center; justify-content: space-between; }
.clear-link { color: #8a9099; font-size: 24rpx; }
.hot-row { display: flex; flex-wrap: wrap; gap: 14rpx; margin-top: 18rpx; }
.hot-word { padding: 10rpx 18rpx; border-radius: 8rpx; color: #555; font-size: 25rpx; background: #f7f8fa; }
.result-list { margin-top: 24rpx; }
.result-card { display: flex; align-items: center; gap: 18rpx; margin-bottom: 16rpx; padding: 22rpx; border-radius: 8rpx; border: 1rpx solid #edf0f2; background: #fff; }
.result-type { padding: 6rpx 10rpx; border-radius: 6rpx; color: #148844; font-size: 22rpx; background: #e7f7ec; }
.result-main { flex: 1; min-width: 0; }
.result-title { display: block; color: #111; font-size: 29rpx; font-weight: 900; }
.result-desc { display: block; margin-top: 8rpx; color: #777; font-size: 24rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.empty { padding: 120rpx 0; display: flex; align-items: center; justify-content: center; flex-direction: column; gap: 16rpx; text-align: center; color: #8a8f98; font-size: 28rpx; }
