<view class="page">
  <view class="header">
    <view class="back-btn" catch:tap="onBack">
      <van-icon name="arrow-left" size="38rpx" color="#111" />
    </view>
    <text class="header-title">{{ scene === 'takeaway' ? '外卖商家' : '校内服务' }}</text>
    <view class="header-placeholder"></view>
  </view>

  <view class="merchant-hero">
    <image class="merchant-cover" src="{{ merchant.coverUrl || merchant.image }}" mode="aspectFill" />
    <view class="merchant-info">
      <view class="name-row">
        <text class="merchant-name">{{ merchant.name }}</text>
        <text class="merchant-tag">{{ merchant.tag }}</text>
      </view>
      <view class="meta-row">
        <text>★ {{ merchant.rating }}</text>
        <text>{{ merchant.distance }}</text>
        <text>{{ merchant.eta }}</text>
        <text>{{ merchant.sales }}</text>
      </view>
      <view class="coupon-row">
        <text wx:for="{{ merchant.coupons }}" wx:key="*this" class="coupon">{{ item }}</text>
      </view>
      <view class="notice-row">
        <van-icon name="volume-o" size="28rpx" color="#148844" />
        <text>{{ merchant.notice }}</text>
      </view>
    </view>
  </view>

  <view class="shop-body">
    <scroll-view class="category-list" scroll-y enhanced show-scrollbar="{{ false }}">
      <view
        wx:for="{{ categories }}"
        wx:key="*this"
        class="category-item {{ activeCategory === item ? 'category-item--active' : '' }}"
        data-category="{{ item }}"
        catch:tap="onCategoryTap"
      >
        {{ item }}
      </view>
    </scroll-view>

    <scroll-view class="product-list" scroll-y enhanced show-scrollbar="{{ false }}">
      <view wx:if="{{ !visibleProducts.length }}" class="empty">当前分类暂无商品</view>
      <view wx:for="{{ visibleProducts }}" wx:key="id" class="product-card">
        <image class="product-img" src="{{ item.image }}" mode="aspectFill" />
        <view class="product-main">
          <text class="product-name">{{ item.name }}</text>
          <text class="product-desc">{{ item.desc }}</text>
          <text class="product-sales">{{ item.sales }}</text>
          <view class="product-bottom">
            <text class="product-price">¥{{ item.price / 100 }}</text>
            <view class="stepper">
              <view wx:if="{{ cart[item.id] }}" class="step-btn" data-id="{{ item.id }}" catch:tap="onMinus">
                <van-icon name="minus" size="26rpx" color="#12b85b" />
              </view>
              <text wx:if="{{ cart[item.id] }}" class="step-count">{{ cart[item.id] }}</text>
              <view class="step-btn step-btn--add" data-id="{{ item.id }}" catch:tap="onAdd">
                <van-icon name="plus" size="26rpx" color="#fff" />
              </view>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="cart-bar">
    <view class="cart-icon-wrap">
      <van-icon name="shopping-cart-o" size="44rpx" color="#fff" />
      <text wx:if="{{ cartCount }}" class="cart-count">{{ cartCount }}</text>
    </view>
    <view class="cart-main">
      <text class="cart-price">¥{{ cartAmount / 100 }}</text>
      <text class="cart-tip">{{ scene === 'takeaway' ? '配送费以结算页为准' : '到店自取免排队' }}</text>
    </view>
    <view class="checkout-btn {{ cartCount ? '' : 'checkout-btn--disabled' }}" catch:tap="onCheckout">去结算</view>
  </view>
</view>
