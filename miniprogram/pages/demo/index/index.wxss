.page { min-height: 100vh; padding: 28rpx; box-sizing: border-box; background: #fbfbfb; }
.header { display: flex; align-items: center; gap: 16rpx; }
.back-btn,.header-placeholder { width: 68rpx; height: 68rpx; display: flex; align-items: center; justify-content: center; }
.header-title { flex: 1; text-align: center; color: #111; font-size: 36rpx; font-weight: 900; }
.panel { margin-top: 24rpx; padding: 30rpx; border: 1rpx solid #edf0f2; border-radius: 8rpx; background: #fff; }
.title { display: block; color: #111; font-size: 34rpx; font-weight: 900; }
.desc { display: block; margin-top: 14rpx; color: #666; font-size: 27rpx; line-height: 1.6; }
.primary-btn,.danger-btn { height: 82rpx; line-height: 82rpx; margin-top: 26rpx; text-align: center; font-size: 29rpx; font-weight: 900; border-radius: 41rpx; }
.primary-btn { color: #fff; background: #12b85b; }
.danger-btn { color: #f0442e; background: #fff5f3; border: 1rpx solid #ffd0c8; }
