<view class="page">
  <view class="header">
    <view class="back-btn" catch:tap="onBack"><van-icon name="arrow-left" size="38rpx" color="#111" /></view>
    <text class="header-title">演示模式</text>
    <view class="header-placeholder"></view>
  </view>
  <view class="panel">
    <text class="title">一键生成演示数据</text>
    <text class="desc">生成帖子、订单、消息等本地模拟数据，方便向同学或协作者展示完整前端流程。</text>
    <view class="primary-btn" catch:tap="onGenerateTap">生成演示数据</view>
    <view class="danger-btn" catch:tap="onClearTap">清空演示数据</view>
  </view>
</view>
