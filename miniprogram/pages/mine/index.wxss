.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 100rpx;
  background: #f7f8fa;
  height: 100vh;
}

.user-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar {
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4fc3f7 0%, #1989fa 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.avatar-text {
  color: #fff;
  font-size: 60rpx;
  font-weight: bold;
}

.nickname {
  font-size: 36rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 60rpx;
}

.logout-btn {
  width: 300rpx;
  font-size: 28rpx;
  color: #ee0a24;
  border: 1rpx solid #ee0a24;
  background: transparent;
}

.login-guide {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.guide-text {
  font-size: 30rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.login-btn {
  width: 300rpx;
  background: #1989fa;
  color: #fff;
  font-size: 30rpx;
}