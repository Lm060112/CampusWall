<view class="page">
  <view class="header">
    <view class="back-btn" catch:tap="onBack">
      <van-icon name="arrow-left" size="38rpx" color="#111" />
    </view>
    <text class="header-title">登录授权</text>
    <view class="header-placeholder"></view>
  </view>

  <view class="login-card">
    <image class="avatar" src="/images/avatar.png" mode="aspectFill" />
    <text class="title">欢迎使用校园生活</text>
    <text class="desc">登录后会同步到云数据库 users 集合，用于后续发布、评论、订单和消息。</text>
    <input class="input" value="{{ nickname }}" placeholder="请输入昵称" bindinput="onNameInput" />
    <input class="input" value="{{ campus }}" placeholder="请输入校区" bindinput="onCampusInput" />
    <view class="login-btn {{ syncing ? 'login-btn--disabled' : '' }}" catch:tap="onLoginTap">
      {{ syncing ? '同步中...' : '授权并进入' }}
    </view>
    <text wx:if="{{ cloudStatus }}" class="cloud-status">{{ cloudStatus }}</text>
  </view>
</view>
