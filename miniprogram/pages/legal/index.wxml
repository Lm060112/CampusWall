<view class="page">
  <view class="header">
    <view class="back-btn" catch:tap="onBack"><van-icon name="arrow-left" size="38rpx" color="#111" /></view>
    <text class="header-title">{{ doc.title }}</text>
    <view class="header-placeholder"></view>
  </view>
  <view class="content-card">
    <text class="title">{{ doc.title }}</text>
    <text wx:for="{{ doc.paragraphs }}" wx:key="*this" class="paragraph">{{ item }}</text>
  </view>
</view>
